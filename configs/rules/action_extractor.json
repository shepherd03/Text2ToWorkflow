{
  "verb_map": {
    "下载": "download_data",
    "获取": "fetch_data",
    "查询": "query_data",
    "清洗": "clean_data",
    "分析": "analyze_data",
    "汇总": "aggregate_data",
    "生成": "generate_output",
    "发送": "send_message",
    "保存": "save_result",
    "通知": "notify_target",
    "校验": "validate_result",
    "告警": "notify_alert",
    "重试": "retry_task",
    "审批": "approve_request",
    "放行": "release_request",
    "调用": "invoke_service",
    "同步": "sync_data",
    "提交": "submit_data"
  },
  "fallback_pattern": "([\\u4e00-\\u9fa5]{2,6})",
  "fallback_suffix": "_task",
  "skip_clause_prefixes": [
    "如果",
    "若",
    "当",
    "否则",
    "失败则",
    "成功则"
  ]
