{
    "valid_types": [
        "data",
        "file",
        "service",
        "target",
        "variable"
    ],
    "regex_rules": [
        {
            "pattern": "https?://[A-Za-z0-9\\-._~:/?#\\[\\]@!$&'()*+,;=%]+",
            "name": "url",
            "type": "service"
        },
        {
            "pattern": "[A-Za-z]:\\\\\\\\[^\\s，,]+",
            "name": "local_path",
            "type": "file"
        },
        {
            "pattern": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}",
            "name": "email",
            "type": "target"
        }
    ],
    "keyword_type_map": {
        "数据": "data",
        "报表": "file",
        "文件": "file",
        "接口": "service",
        "API": "service",
        "邮箱": "target",
        "变量": "variable"
    },
    "fallback_resource": {
        "name": "task_context",
        "type": "data"
    }
}